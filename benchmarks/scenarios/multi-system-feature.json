    {"file": "**/*Message*.cs", "pattern": "readonly struct.*ScoreChanged"}
  ],
  "forbidden_patterns": [
    {"file": "**/CoinSystem.cs", "pattern": "MonoBehaviour"},
    {"file": "**/CoinModel.cs", "pattern": "MonoBehaviour"},
    {"file": "**/*.cs", "pattern": "FindObjectOfType"},
    {"file": "**/*.cs", "pattern": "static.*Instance"}
  ]
}
